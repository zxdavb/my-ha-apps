#!/opt/venv/bin/python3
"""Garmy sync wrapper for the Home Assistant add-on.

Authenticates via stored tokens in $HOME/.garmy (= /data/.garmy when HOME=/data).
Tokens are seeded there by the garmy_tokens cont-init.d step (from pasted
config) or copied in manually; this add-on runs headlessly and cannot
complete an interactive Garmin login (email/password + MFA) on its own.
"""
import json
import os
import sys
from datetime import date, timedelta
from pathlib import Path

DEBUG = os.environ.get("GARMY_DEBUG") == "1"


def _debug(msg: str) -> None:
    if DEBUG:
        print(f"[debug] {msg}", file=sys.stderr)


def _debug_token_files(tokens_dir: Path) -> None:
    if not DEBUG:
        return
    _debug(f"tokens_dir={tokens_dir}")
    for name in ("oauth1_token.json", "oauth2_token.json"):
        path = tokens_dir / name
        if not path.exists():
            _debug(f"{name}: missing")
            continue
        st = path.stat()
        _debug(f"{name}: exists, {st.st_size} bytes, mtime={st.st_mtime}")
        try:
            data = json.loads(path.read_text())
        except Exception as exc:
            _debug(f"{name}: JSON parse failed: {exc}")
            continue
        keys = list(data.keys()) if isinstance(data, dict) else type(data).__name__
        _debug(f"{name}: valid JSON, keys={keys}")


def main() -> int:
    db_path_str = os.environ.get("GARMY_DB_PATH")
    if not db_path_str:
        print("ERROR: GARMY_DB_PATH not set", file=sys.stderr)
        return 1

    days = int(os.environ.get("GARMY_SYNC_DAYS", "7"))

    from garmy.auth.client import AuthClient
    from garmy import APIClient
    from garmy.localdb.sync import SyncManager
    from garmy.localdb.config import LocalDBConfig
    from garmy.localdb.progress import ProgressReporter
    from garmy.localdb.activities_iterator import ActivitiesIterator

    auth = AuthClient()  # loads from ~/.garmy, which is /data/.garmy when HOME=/data
    _debug_token_files(Path(os.environ.get("HOME", "")) / ".garmy")
    _debug(f"auth.is_authenticated={auth.is_authenticated}")

    if not auth.is_authenticated:
        print(
            "No valid Garmin tokens found.\n"
            "Set garmin.oauth1_token_json and garmin.oauth2_token_json in the "
            "add-on configuration, or copy token files to /data/.garmy/ manually.",
            file=sys.stderr,
        )
        return 2
    print("Using cached Garmin tokens.")

    db_path = Path(db_path_str)
    db_path.parent.mkdir(parents=True, exist_ok=True)

    config = LocalDBConfig()
    progress = ProgressReporter(use_tqdm=False)

    manager = SyncManager(db_path=db_path, config=config, progress_reporter=progress)
    manager.api_client = APIClient(auth_client=auth)

    try:
        manager.activities_iterator = ActivitiesIterator(
            manager.api_client, config.sync, progress
        )
        manager.activities_iterator.initialize()
    except Exception as exc:
        print(f"Warning: activities iterator failed to initialise ({exc}); activities will be skipped.", file=sys.stderr)

    end = date.today()
    start = end - timedelta(days=days - 1)
    print(f"Syncing {days} day(s): {start} to {end}...")

    stats = manager.sync_range(user_id=1, start_date=start, end_date=end)
    print(
        f"Sync complete: {stats['completed']} synced, "
        f"{stats['skipped']} skipped, "
        f"{stats['failed']} failed."
    )
    return 0 if stats["failed"] == 0 else 1


if __name__ == "__main__":
    sys.exit(main())

#!/usr/bin/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Write Garmin OAuth token files from pasted config JSON on every startup, so
# accounts with 2FA can be authenticated once (interactively, elsewhere) and
# the resulting tokens handed to this headless add-on without SSH/Samba
# access. Each of garmin.oauth1_token_json / garmin.oauth2_token_json is
# written independently, unconditionally overwriting the matching file in
# /data/.garmy/ whenever it's set; leave a field blank to leave that file
# untouched (e.g. to keep tokens garmy-sync has since refreshed on disk).
# ==============================================================================

set -euo pipefail

if bashio::config.true 'advanced.debug_logging'; then
    bashio::log.level "debug"
    set -x
fi

tokens_dir="/data/.garmy"
mkdir -p "${tokens_dir}"

write_token_file() {
    local filename="$1" option_name="$2" raw

    if ! bashio::config.has_value "${option_name}"; then
        bashio::log.debug "${option_name} is blank; leaving ${filename} untouched."
        return 0
    fi

    raw="$(bashio::config "${option_name}")"
    GARMY_TOKEN_JSON="${raw}" GARMY_TOKEN_FILE="${tokens_dir}/${filename}" GARMY_OPTION_NAME="${option_name}" python3 <<'EOF'
import json
import os
import stat
import sys
from pathlib import Path

raw = os.environ["GARMY_TOKEN_JSON"]
path = Path(os.environ["GARMY_TOKEN_FILE"])
option_name = os.environ["GARMY_OPTION_NAME"]

try:
    data = json.loads(raw)
except json.JSONDecodeError as exc:
    print(f"ERROR: {option_name} is not valid JSON: {exc}", file=sys.stderr)
    sys.exit(1)
if not isinstance(data, dict):
    print(f"ERROR: {option_name} must be a JSON object.", file=sys.stderr)
    sys.exit(1)

path.write_text(json.dumps(data))
path.chmod(stat.S_IRUSR | stat.S_IWUSR)
print(f"Wrote {path} from {option_name}.")
EOF
}

write_token_file "oauth1_token.json" "garmin.oauth1_token_json"
write_token_file "oauth2_token.json" "garmin.oauth2_token_json"

bashio::log.debug "$(ls -la "${tokens_dir}")"

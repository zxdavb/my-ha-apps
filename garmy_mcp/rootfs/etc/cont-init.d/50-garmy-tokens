#!/usr/bin/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Write the Garmin OAuth1 token file from pasted config JSON, so accounts
# with 2FA can be authenticated once (interactively, elsewhere) and the
# result handed to this headless add-on without SSH/Samba access.
#
# OAuth1 is the durable "login" credential; garmy-sync-ha mints a fresh,
# short-lived OAuth2 access token from it on demand (AuthClient.
# refresh_tokens(), which needs nothing but a valid OAuth1 token), so
# there's no need to also paste an OAuth2 token here.
#
# garmin.oauth1_token_json doubles as a change signal: if it matches what we
# wrote last time, /data/.garmy/ is left alone (so an OAuth2 token refreshed
# since the last restart isn't clobbered); if it has changed (a fresh
# interactive login was pasted in), oauth1_token.json is rewritten and any
# existing oauth2_token.json is removed, since it belonged to the old login
# and garmy-sync-ha will mint a new one to match. Leave the field blank to
# manage /data/.garmy/ yourself (e.g. manually-copied token files).
# ==============================================================================

set -euo pipefail

if bashio::config.true 'advanced.debug_logging'; then
    bashio::log.level "debug"
fi

tokens_dir="/data/.garmy"
mkdir -p "${tokens_dir}"
fingerprint_file="${tokens_dir}/.oauth1_config_seeded"

if ! bashio::config.has_value 'garmin.oauth1_token_json'; then
    bashio::log.debug "garmin.oauth1_token_json is blank; leaving ${tokens_dir} untouched."
    exit 0
fi

oauth1_raw="$(bashio::config 'garmin.oauth1_token_json')"
previous_raw=""
if [[ -f "${fingerprint_file}" ]]; then
    previous_raw="$(cat "${fingerprint_file}")"
fi

if [[ "${oauth1_raw}" == "${previous_raw}" ]]; then
    bashio::log.debug "garmin.oauth1_token_json unchanged since last seed; leaving ${tokens_dir} untouched (preserves any token garmy-sync has refreshed)."
else
    bashio::log.info "garmin.oauth1_token_json is new or changed; writing oauth1_token.json from config."

    GARMY_TOKEN_JSON="${oauth1_raw}" GARMY_TOKEN_FILE="${tokens_dir}/oauth1_token.json" python3 <<'EOF'
import json
import os
import stat
import sys
from pathlib import Path

raw = os.environ["GARMY_TOKEN_JSON"]
path = Path(os.environ["GARMY_TOKEN_FILE"])

try:
    data = json.loads(raw)
except json.JSONDecodeError as exc:
    print(f"ERROR: garmin.oauth1_token_json is not valid JSON: {exc}", file=sys.stderr)
    sys.exit(1)
if not isinstance(data, dict):
    print("ERROR: garmin.oauth1_token_json must be a JSON object.", file=sys.stderr)
    sys.exit(1)

path.write_text(json.dumps(data))
path.chmod(stat.S_IRUSR | stat.S_IWUSR)
print(f"Wrote {path}.")
EOF

    rm -f "${tokens_dir}/oauth2_token.json"
    printf '%s' "${oauth1_raw}" > "${fingerprint_file}"
    chmod 600 "${fingerprint_file}"
fi

bashio::log.debug "$(ls -la "${tokens_dir}")"
